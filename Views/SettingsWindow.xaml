<Window x:Class="ProxyMaster.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:ProxyMaster.Core"
        Title="{Binding [settings_title], Source={x:Static core:LocalizationService.Instance}}"
        Width="480" SizeToContent="Height" MinHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundDarkBrush}"
        FontFamily="Segoe UI">

  <Window.Resources>
    <!-- Кнопка выбора языка -->
    <Style x:Key="LangButton" TargetType="Button">
      <Setter Property="Width"           Value="96"/>
      <Setter Property="Height"          Value="34"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="BorderThickness" Value="2"/>
      <Setter Property="Margin"          Value="4"/>
      <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="Background"      Value="{DynamicResource BackgroundLightBrush}"/>
      <Setter Property="BorderBrush"     Value="{DynamicResource BorderColorBrush}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Активный язык -->
    <Style x:Key="LangButtonActive" TargetType="Button" BasedOn="{StaticResource LangButton}">
      <Setter Property="Background"  Value="{DynamicResource AccentBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground"  Value="White"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>
  </Window.Resources>

  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="16"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Язык -->
    <StackPanel Grid.Row="0">
      <TextBlock Text="{Binding [settings_lang], Source={x:Static core:LocalizationService.Instance}}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
      <WrapPanel x:Name="LangPanel"/>
    </StackPanel>

    <!-- Разделитель -->
    <Border Grid.Row="1" Height="1" Background="{DynamicResource BorderColorBrush}"
            VerticalAlignment="Center" Margin="0,8"/>

    <!-- Цветовая схема -->
    <StackPanel Grid.Row="2">
      <TextBlock Text="{Binding [settings_theme], Source={x:Static core:LocalizationService.Instance}}"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 FontSize="11" FontWeight="SemiBold" Margin="0,0,0,10"/>
      <WrapPanel x:Name="ThemePanel"/>
    </StackPanel>

    <!-- Кнопка закрыть -->
    <Button Grid.Row="6"
            Content="{Binding [btn_close], Source={x:Static core:LocalizationService.Instance}}"
            Style="{StaticResource PrimaryButton}"
            HorizontalAlignment="Right"
            Padding="28,8"
            Click="CloseBtn_Click"/>
  </Grid>
</Window>
