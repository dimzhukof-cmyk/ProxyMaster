<Window x:Class="ProxyMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProxyMaster.ViewModels"
        xmlns:models="clr-namespace:ProxyMaster.Models"
        Title="ProxyMaster" Height="620" Width="820"
        MinHeight="500" MinWidth="700"
        Background="{StaticResource BackgroundDarkBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="56"/>   <!-- Заголовок -->
      <RowDefinition Height="Auto"/> <!-- Статус -->
      <RowDefinition Height="Auto"/> <!-- Настройки -->
      <RowDefinition Height="*"/>    <!-- Лог -->
      <RowDefinition Height="36"/>   <!-- Статусбар -->
    </Grid.RowDefinitions>

    <!-- ======= Заголовок ======= -->
    <Border Grid.Row="0" Background="{StaticResource BackgroundMidBrush}">
      <Grid Margin="16,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0">
            <Ellipse.Effect>
              <DropShadowEffect Color="{Binding StatusColor}" BlurRadius="6" ShadowDepth="0"/>
            </Ellipse.Effect>
          </Ellipse>
          <TextBlock Text="ProxyMaster" Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          <TextBlock Text=" — системный прокси для Windows"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="13" VerticalAlignment="Center" Margin="4,2,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold"
                     Foreground="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,16,0"/>
          <Button Content="▶ ЗАПУСТИТЬ" Style="{StaticResource PrimaryButton}"
                  Command="{Binding StartCommand}" Margin="0,0,8,0"/>
          <Button Content="■ СТОП" Style="{StaticResource DangerButton}"
                  Command="{Binding StopCommand}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ======= Настройки прокси ======= -->
    <Border Grid.Row="2" Background="{StaticResource BackgroundMidBrush}"
            Margin="0,1,0,0" Padding="16,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="90"/>
          <ColumnDefinition Width="160"/>
          <ColumnDefinition Width="160"/>
          <ColumnDefinition Width="80"/>
        </Grid.ColumnDefinitions>

        <!-- Тип прокси -->
        <StackPanel Grid.Column="0" Margin="0,0,8,0">
          <TextBlock Text="Тип" Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" Margin="0,0,0,4"/>
          <ComboBox SelectedValue="{Binding ProxyType}"
                    SelectedValuePath="Tag"
                    Style="{StaticResource DarkComboBox}">
            <ComboBoxItem Content="SOCKS5" Tag="{x:Static models:ProxyType.Socks5}"/>
            <ComboBoxItem Content="HTTP"   Tag="{x:Static models:ProxyType.Http}"/>
          </ComboBox>
        </StackPanel>

        <!-- Хост -->
        <StackPanel Grid.Column="1" Margin="0,0,8,0">
          <TextBlock Text="Адрес сервера" Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" Margin="0,0,0,4"/>
          <TextBox Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource DarkTextBox}"/>
        </StackPanel>

        <!-- Порт -->
        <StackPanel Grid.Column="2" Margin="0,0,8,0">
          <TextBlock Text="Порт" Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" Margin="0,0,0,4"/>
          <TextBox Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource DarkTextBox}"/>
        </StackPanel>

        <!-- Логин -->
        <StackPanel Grid.Column="3" Margin="0,0,8,0">
          <TextBlock Text="Логин (необязательно)" Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" Margin="0,0,0,4"/>
          <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource DarkTextBox}"/>
        </StackPanel>

        <!-- Пароль -->
        <StackPanel Grid.Column="4" Margin="0,0,8,0">
          <TextBlock Text="Пароль" Foreground="{StaticResource TextSecondaryBrush}"
                     FontSize="11" Margin="0,0,0,4"/>
          <PasswordBox x:Name="PasswordInput"
                       Background="{StaticResource BackgroundLightBrush}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       BorderBrush="#44445A" BorderThickness="1"
                       Padding="8,6" FontSize="13"/>
        </StackPanel>

        <!-- Сохранить -->
        <StackPanel Grid.Column="5" VerticalAlignment="Bottom">
          <Button Content="Сохранить" Style="{StaticResource PrimaryButton}"
                  Command="{Binding SaveCommand}"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ======= Лог ======= -->
    <Border Grid.Row="3" Margin="0,1,0,0" Background="{StaticResource BackgroundDarkBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="32"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок лога -->
        <Border Grid.Row="0" Background="{StaticResource BackgroundMidBrush}" Padding="12,0">
          <Grid>
            <TextBlock Text="Журнал событий" Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center"/>
            <Button Content="Очистить" HorizontalAlignment="Right"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ClearLogCommand}"
                    Padding="10,4" FontSize="11"/>
          </Grid>
        </Border>

        <!-- Список логов -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding LogLines}"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 FontFamily="Consolas" FontSize="12"
                 x:Name="LogList"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding" Value="12,2"/>
              <Setter Property="Background" Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="#2A2A3E"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>
    </Border>

    <!-- ======= Статусбар ======= -->
    <Border Grid.Row="4" Background="{StaticResource BackgroundMidBrush}" Padding="12,0">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Передано: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
          <TextBlock Text="{Binding BytesDisplay}" Foreground="{StaticResource TextPrimaryBrush}"
                     FontSize="11" Margin="0,0,24,0"/>
          <TextBlock Text="Записей в таблице: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
          <TextBlock Text="{Binding ActiveConnections}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="11"/>
        </StackPanel>

        <TextBlock Text="WinDivert · SOCKS5/HTTP · TCP"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
      </Grid>
    </Border>
  </Grid>
</Window>
