<Window x:Class="ProxyMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProxyMaster.ViewModels"
        xmlns:models="clr-namespace:ProxyMaster.Models"
        xmlns:core="clr-namespace:ProxyMaster.Core"
        Title="ProxyMaster" Height="700" Width="820"
        Icon="pack://application:,,,/Icon/PM_logo_256x256.png"
        MinHeight="560" MinWidth="700"
        Background="{DynamicResource BackgroundDarkBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

  <Window.DataContext>
    <vm:MainViewModel/>
  </Window.DataContext>

  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <Style x:Key="DarkRadio" TargetType="RadioButton">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="FontSize"   Value="12"/>
      <Setter Property="Margin"     Value="0,0,16,0"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <Style x:Key="ProcessRowStyle" TargetType="ListViewItem">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource TextPrimaryBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="4,3"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource BackgroundMidBrush}"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource BackgroundLightBrush}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="56"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="36"/>
    </Grid.RowDefinitions>

    <!-- ======= Заголовок ======= -->
    <Border Grid.Row="0" Background="{DynamicResource BackgroundMidBrush}">
      <Grid Margin="16,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" Margin="0,0,8,0">
            <Ellipse.Effect>
              <DropShadowEffect Color="{Binding StatusColor}" BlurRadius="6" ShadowDepth="0"/>
            </Ellipse.Effect>
          </Ellipse>
          <TextBlock Text="ProxyMaster"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding Loc[app_subtitle], StringFormat=' — {0}'}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="13" VerticalAlignment="Center" Margin="4,2,0,0"/>
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}" FontSize="12" FontWeight="Bold"
                     Foreground="{Binding StatusColor}" VerticalAlignment="Center" Margin="0,0,16,0"/>
          <Button Content="{Binding Loc[btn_start]}" Style="{StaticResource PrimaryButton}"
                  Command="{Binding StartCommand}" Margin="0,0,8,0"/>
          <Button Content="{Binding Loc[btn_stop]}"  Style="{StaticResource DangerButton}"
                  Command="{Binding StopCommand}"    Margin="0,0,8,0"/>
          <!-- Кнопка настроек -->
          <Button Content="⚙" Style="{StaticResource PrimaryButton}"
                  Command="{Binding SettingsCommand}"
                  Padding="10,8" FontSize="15" ToolTip="{Binding Loc[settings_title]}"
                  Margin="0,0,8,0"/>
          <!-- Компактный режим -->
          <Button Content="⊡" Style="{StaticResource PrimaryButton}"
                  Command="{Binding ToggleCompactCommand}"
                  Padding="10,8" FontSize="15" ToolTip="Компактный вид"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ======= Настройки прокси ======= -->
    <Border Grid.Row="1" Background="{DynamicResource BackgroundMidBrush}"
            Margin="0,1,0,0" Padding="16,12"
            Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="8"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Saved servers row -->
        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="36"/>
            <ColumnDefinition Width="36"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Text="{Binding Loc[lbl_saved_servers]}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding SavedServers}"
                    SelectedIndex="{Binding ActiveServerIndex}"
                    DisplayMemberPath="DisplayName"
                    Style="{StaticResource DarkComboBox}"
                    Margin="0,0,8,0"/>
          <Button Grid.Column="2" Content="+"
                  Style="{StaticResource PrimaryButton}"
                  Command="{Binding AddServerCommand}"
                  Padding="0" FontSize="15" FontWeight="Light" Margin="0,0,4,0"/>
          <Button Grid.Column="3" Content="−"
                  Style="{StaticResource DangerButton}"
                  Command="{Binding DeleteServerCommand}"
                  Padding="0" FontSize="15" FontWeight="Light"/>
        </Grid>

        <!-- Proxy fields -->
        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="90"/>
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Margin="0,0,8,0">
            <TextBlock Text="{Binding Loc[lbl_type]}"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <ComboBox SelectedValue="{Binding ProxyType}" SelectedValuePath="Tag"
                      Style="{StaticResource DarkComboBox}">
              <ComboBoxItem Content="SOCKS5" Tag="{x:Static models:ProxyType.Socks5}"/>
              <ComboBoxItem Content="HTTP"   Tag="{x:Static models:ProxyType.Http}"/>
            </ComboBox>
          </StackPanel>

          <StackPanel Grid.Column="1" Margin="0,0,8,0">
            <TextBlock Text="{Binding Loc[lbl_host]}"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ProxyHost, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}"/>
          </StackPanel>

          <StackPanel Grid.Column="2" Margin="0,0,8,0">
            <TextBlock Text="{Binding Loc[lbl_port]}"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ProxyPort, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}"/>
          </StackPanel>

          <StackPanel Grid.Column="3" Margin="0,0,8,0">
            <TextBlock Text="{Binding Loc[lbl_login]}"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DarkTextBox}"/>
          </StackPanel>

          <StackPanel Grid.Column="4" Margin="0,0,8,0">
            <TextBlock Text="{Binding Loc[lbl_password]}"
                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PasswordInput"
                         Background="{DynamicResource BackgroundLightBrush}"
                         Foreground="{DynamicResource TextPrimaryBrush}"
                         BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="1"
                         Padding="8,6" FontSize="13"/>
          </StackPanel>

          <StackPanel Grid.Column="5" VerticalAlignment="Bottom">
            <Button Content="{Binding Loc[btn_save]}" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"/>
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <!-- ======= Фильтр приложений ======= -->
    <Border Grid.Row="2" Background="{DynamicResource BackgroundMidBrush}" Margin="0,1,0,0" Padding="16,10"
            Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="{Binding Loc[lbl_traffic]}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <RadioButton Content="{Binding Loc[opt_all_apps]}"
                         IsChecked="{Binding FilterByProcessAll}"
                         GroupName="AppFilter" Style="{StaticResource DarkRadio}"/>
            <RadioButton Content="{Binding Loc[opt_selected]}"
                         IsChecked="{Binding FilterByProcess}"
                         GroupName="AppFilter" Style="{StaticResource DarkRadio}"/>
          </StackPanel>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                      Visibility="{Binding ShowProcessList, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SelectedProcessCount}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button Content="{Binding Loc[btn_refresh]}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding RefreshProcessesCommand}"
                    Padding="10,4" FontSize="11"/>
          </StackPanel>
        </Grid>

        <!-- Search box -->
        <Grid Grid.Row="1" Margin="0,8,0,0"
              Visibility="{Binding ShowProcessList, Converter={StaticResource BoolToVis}}">
          <TextBox x:Name="ProcessSearchBox"
                   Text="{Binding ProcessFilter, UpdateSourceTrigger=PropertyChanged}"
                   Style="{StaticResource DarkTextBox}"/>
          <TextBlock Text="{Binding Loc[lbl_search]}"
                     IsHitTestVisible="False"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12" Padding="10,6" Opacity="0.6">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding Text, ElementName=ProcessSearchBox}" Value="">
                    <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </Grid>

        <!-- Список процессов -->
        <Border Grid.Row="2" Margin="0,6,0,0"
                Visibility="{Binding ShowProcessList, Converter={StaticResource BoolToVis}}"
                BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="1">
          <ListView ItemsSource="{Binding FilteredProcesses}"
                    Height="160"
                    Background="{DynamicResource BackgroundDarkBrush}"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource ProcessRowStyle}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling"
                    SelectionMode="Single">
            <ListView.View>
              <GridView>
                <!-- Чекбокс -->
                <GridViewColumn Width="36">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                HorizontalAlignment="Center"/>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>

                <!-- Иконка -->
                <GridViewColumn Width="28">
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <Image Source="{Binding Icon}" Width="16" Height="16"
                             RenderOptions.BitmapScalingMode="HighQuality"/>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>

                <!-- Имя процесса -->
                <GridViewColumn Width="150">
                  <GridViewColumn.Header>
                    <TextBlock Text="{Binding [lbl_process], Source={x:Static core:LocalizationService.Instance}}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                  </GridViewColumn.Header>
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Name}"
                                 Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"/>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>

                <!-- Путь -->
                <GridViewColumn Width="530">
                  <GridViewColumn.Header>
                    <TextBlock Text="{Binding [lbl_path], Source={x:Static core:LocalizationService.Instance}}"
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
                  </GridViewColumn.Header>
                  <GridViewColumn.CellTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding DisplayPath}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 FontSize="11" TextTrimming="CharacterEllipsis"/>
                    </DataTemplate>
                  </GridViewColumn.CellTemplate>
                </GridViewColumn>
              </GridView>
            </ListView.View>
          </ListView>
        </Border>
      </Grid>
    </Border>

    <!-- ======= Лог ======= -->
    <Border Grid.Row="3" Margin="0,1,0,0" Background="{DynamicResource BackgroundDarkBrush}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="32"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Background="{DynamicResource BackgroundMidBrush}" Padding="12,4">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="{Binding Loc[lbl_log]}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>

            <!-- Поиск по логу -->
            <Grid Grid.Column="1" Margin="0,0,8,0">
              <TextBox x:Name="LogSearchBox"
                       Text="{Binding LogFilter, UpdateSourceTrigger=PropertyChanged}"
                       Style="{StaticResource DarkTextBox}"
                       FontFamily="Consolas" FontSize="12"/>
              <TextBlock Text="Поиск..."
                         IsHitTestVisible="False"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         FontSize="12" Padding="10,5" Opacity="0.5">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Text, ElementName=LogSearchBox}" Value="">
                        <Setter Property="Visibility" Value="Visible"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Grid>

            <Button Grid.Column="2"
                    Content="{Binding Loc[btn_clear]}"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ClearLogCommand}"
                    Padding="10,4" FontSize="11"/>
          </Grid>
        </Border>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding LogLines}"
                 Background="Transparent" BorderThickness="0"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 FontFamily="Consolas" FontSize="12"
                 x:Name="LogList"
                 SelectionMode="Extended"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Padding"         Value="12,2"/>
              <Setter Property="Background"      Value="Transparent"/>
              <Setter Property="BorderThickness" Value="0"/>
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="{DynamicResource BackgroundMidBrush}"/>
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
        </ListBox>
      </Grid>
    </Border>

    <!-- ======= Компактный вид (покрывает всё окно) ======= -->
    <Grid Grid.RowSpan="5"
          Visibility="{Binding IsCompactMode, Converter={StaticResource BoolToVis}}"
          Panel.ZIndex="20"
          Background="#FF0A0F1F"
          ClipToBounds="True">

      <!-- Глобус OFF (тёмный) — 922×922 по центру, края обрезаются -->
      <Image Source="pack://application:,,,/Icon/ProxyMaster_compact_screen_off.jpg"
             Width="738" Height="738"
             HorizontalAlignment="Center" VerticalAlignment="Center"
             Stretch="UniformToFill">
        <Image.Style>
          <Style TargetType="Image">
            <Setter Property="Opacity" Value="1"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRunning}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       To="0" Duration="0:0:0.7"/>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       To="1" Duration="0:0:0.5"/>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.ExitActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Image.Style>
      </Image>

      <!-- Глобус ON (голубой с орбитами) — 922×922 по центру -->
      <Image Source="pack://application:,,,/Icon/ProxyMaster_compact_screen.jpg"
             Width="738" Height="738"
             HorizontalAlignment="Center" VerticalAlignment="Center"
             Stretch="UniformToFill">
        <Image.Style>
          <Style TargetType="Image">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRunning}" Value="True">
                <DataTrigger.EnterActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       To="1" Duration="0:0:0.7"/>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                  <BeginStoryboard>
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                       To="0" Duration="0:0:0.5"/>
                    </Storyboard>
                  </BeginStoryboard>
                </DataTrigger.ExitActions>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Image.Style>
      </Image>

      <!-- Кнопка START/STOP — по центру, только вокруг текста -->
      <Button Command="{Binding ToggleProxyCommand}" Cursor="Hand"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Padding="32,12">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Border Background="Transparent">
              <TextBlock FontFamily="Inter" FontWeight="Black" FontSize="88"
                         HorizontalAlignment="Center">
                <TextBlock.Style>
                  <Style TargetType="TextBlock">
                    <Setter Property="Text"       Value="START"/>
                    <Setter Property="Foreground" Value="#3AB4E8"/>
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding DataContext.IsRunning,
                                   RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                        <Setter Property="Text"       Value="STOP"/>
                        <Setter Property="Foreground" Value="#0D1B2E"/>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>
            </Border>
          </ControlTemplate>
        </Button.Template>
      </Button>

      <!-- ── Шапка ── -->
      <Grid VerticalAlignment="Top" Margin="28,22,16,0" IsHitTestVisible="True">

        <!-- PROXYMASTER + статус (слева) -->
        <StackPanel HorizontalAlignment="Left">
          <TextBlock Text="PROXYMASTER"
                     FontFamily="Segoe UI" FontSize="22" FontWeight="Bold"
                     Foreground="White"/>
          <TextBlock FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" Margin="0,3,0,0">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Text"       Value="OFF"/>
                <Setter Property="Foreground" Value="#FF5050"/>
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsRunning}" Value="True">
                    <Setter Property="Text"       Value="ON"/>
                    <Setter Property="Foreground" Value="#3AE8D0"/>
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>

        <!-- Иконки справа: [⚙ настройки] [⛶ развернуть] -->
        <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top"
                    Orientation="Horizontal">
          <!-- Настройки -->
          <Button Command="{Binding SettingsCommand}" Cursor="Hand" ToolTip="Настройки"
                  Width="44" Height="44" Margin="0,0,4,0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <TextBlock Text="&#xE713;"
                           FontFamily="Segoe MDL2 Assets" FontSize="26"
                           Foreground="#CCFFFFFF"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver,
                                     RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                          <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </ControlTemplate>
            </Button.Template>
          </Button>
          <!-- Развернуть -->
          <Button Command="{Binding ToggleCompactCommand}" Cursor="Hand" ToolTip="Развернуть"
                  Width="44" Height="44">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <TextBlock Text="&#xE1D9;"
                           FontFamily="Segoe MDL2 Assets" FontSize="26"
                           Foreground="#CCFFFFFF"
                           HorizontalAlignment="Center" VerticalAlignment="Center">
                  <TextBlock.Style>
                    <Style TargetType="TextBlock">
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver,
                                     RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                          <Setter Property="Foreground" Value="White"/>
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </TextBlock.Style>
                </TextBlock>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ── Нижний блок с информацией ── -->
      <Border VerticalAlignment="Bottom" Height="120" IsHitTestVisible="True">
        <Border.Background>
          <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#000A0F1F"     Offset="0"/>
            <GradientStop Color="#DD0A0F1F"     Offset="0.4"/>
            <GradientStop Color="#FF0A0F1F"     Offset="1"/>
          </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="28,0,20,20" VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- SERVER (слева) -->
          <StackPanel Grid.Column="0" VerticalAlignment="Center">
            <TextBlock Text="SERVER"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                       Foreground="#7A9EC2" Margin="0,0,0,4"/>
            <TextBlock FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                       Foreground="#D9EAFF">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} : {1}">
                  <Binding Path="ProxyHost"/>
                  <Binding Path="ProxyPort"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
            <TextBlock Text="{Binding ProxyTypeDisplay}"
                       FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                       Foreground="#3A8BD4" Margin="0,4,0,0"/>
          </StackPanel>

          <!-- TRAFFIC (справа) — на том же уровне что SERVER -->
          <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
            <TextBlock Text="TRAFFIC"
                       FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                       Foreground="#7A9EC2" HorizontalAlignment="Right" Margin="0,0,0,4"/>
            <TextBlock Text="{Binding BytesDisplay}"
                       FontFamily="Segoe UI" FontSize="18" FontWeight="Bold"
                       Foreground="#D9EAFF" HorizontalAlignment="Right"/>
            <TextBlock FontFamily="Segoe UI" FontSize="12"
                       Foreground="#6699BB" HorizontalAlignment="Right" Margin="0,4,0,0">
              <TextBlock.Text>
                <MultiBinding StringFormat="{}{0} conn">
                  <Binding Path="ActiveConnections"/>
                </MultiBinding>
              </TextBlock.Text>
            </TextBlock>
          </StackPanel>
        </Grid>
      </Border>
    </Grid>

    <!-- ======= Статусбар ======= -->
    <Border Grid.Row="4" Background="{DynamicResource BackgroundMidBrush}" Padding="12,0"
            Visibility="{Binding IsFullMode, Converter={StaticResource BoolToVis}}">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="{Binding Loc[lbl_transferred]}"
                     Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
          <TextBlock Text="{Binding BytesDisplay}"
                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11" Margin="0,0,24,0"/>
          <TextBlock Text="{Binding Loc[lbl_table]}"
                     Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"/>
          <TextBlock Text="{Binding ActiveConnections}"
                     Foreground="{DynamicResource TextPrimaryBrush}" FontSize="11"/>
        </StackPanel>
        <TextBlock Text="WinDivert · SOCKS5/HTTP · TCP"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
      </Grid>
    </Border>
  </Grid>
</Window>
